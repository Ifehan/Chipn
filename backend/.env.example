# Database
DATABASE_URL=postgresql://user:STRONG_RANDOM_PASSWORD@localhost:5432/chipn_db

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# M-Pesa Daraja
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_ENVIRONMENT=sandbox
# Append ?secret=YOUR_CALLBACK_SECRET to the URL — generate with: openssl rand -hex 24
MPESA_CALLBACK_URL=https://your-domain.com/mpesa/callback?secret=YOUR_CALLBACK_SECRET
MPESA_CALLBACK_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_24

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Chipn <onboarding@resend.dev>

# CORS
FRONTEND_URL=https://your-production-domain.com

# Environment: development | production
ENVIRONMENT=development
